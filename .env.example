# 이 파일을 복사해서 .env.local로 저장하고 실제 값을 채워주세요.
# .env.local은 .gitignore에 의해 커밋되지 않습니다.

# Supabase — 클라이언트/서버 공용
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — 서버 전용 (app/api/v1/[username]/[slug] 라우트에서 RLS를 우회할 때 사용)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — /api/chat, /api/parse-deadlines에서 gpt-4.1-mini 호출에 사용
OPENAI_API_KEY=

# Tavily — 선택 사항. 없으면 "최신 정보 검색" 블록이 검색 없이 안내 문구만 반환합니다.
TAVILY_API_KEY=
